# -------------------------
# sample parsing via checkpoint
# -------------------------
def get_samples_df():
    ckpt = checkpoints.download_metadata.get()
    samples_file = ckpt.output.samples

    df = pd.read_csv(samples_file)

    # clean whitespace just in case
    df["Name"] = df["Name"].astype(str).str.strip()
    df["R1_file"] = df["R1_file"].astype(str).str.strip().str.lstrip("/")
    df["R2_file"] = df["R2_file"].astype(str).str.strip().str.lstrip("/")
    df["Path"] = df["Path"].astype(str).str.strip().str.rstrip("/")

    return df


def get_sample_names():
    df = get_samples_df()
    return df["Name"].tolist()


def get_fastq_r1(sample):
    df = get_samples_df()
    row = df.loc[df["Name"] == sample]
    if row.empty:
        raise ValueError(f"Sample {sample} not found in sample sheet")
    return f'gs://{row.iloc[0]["Path"]}/{row.iloc[0]["R1_file"]}'


def get_fastq_r2(sample):
    df = get_samples_df()
    row = df.loc[df["Name"] == sample]
    if row.empty:
        raise ValueError(f"Sample {sample} not found in sample sheet")
    return f'gs://{row.iloc[0]["Path"]}/{row.iloc[0]["R2_file"]}'


def all_fastp_outputs(wildcards):
    samples = get_sample_names()
    return (
        expand(str(QC_DIR / "fastp" / "{sample}.fastp.html"), sample=samples)
        + expand(str(QC_DIR / "fastp" / "{sample}.fastp.json"), sample=samples)
    )

# -------------------------
# including rules
# -------------------------
include: "rules/references_combined.smk"
include: "rules/download_samples.smk"
include: "rules/fastp_trimming.smk"

onstart:
    print("\n--- Analysis started ---\n")

onsuccess:
    print("\n--- Workflow finished! ---\n")

onerror:
    print("\n--- An error occurred! ---\n")

# -------------------------
# rule all
# -------------------------
rule all:
    input:
        all_fastp_outputs
    default_target: True
