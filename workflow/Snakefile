# -------------------------
# rule all
# -------------------------

#  need to define outputs in a function because when we pull samples from an external file you cannot immediately know all samples. Sample list must be generated after checkpoint runs that downloads the sample file
def all_current_outputs(wildcards):
    samples = get_sample_names()
    return expand(str(UPLOAD_DIR / "{sample}.upload.done"), sample=samples)

rule all:
    input:
        all_current_outputs
    default_target: True

